+float3 ToneMapExtendedReinhard(float3 x, float whitePoint)
+{
+    float white2 = max(whitePoint * whitePoint, 0.01);
+    return (x * (1.0 + x / white2)) / (1.0 + x);
+}
+
+float3 ToneMapACESFitted(float3 x)
+{
+    const float a = 2.51;
+    const float b = 0.03;
+    const float c = 2.43;
+    const float d = 0.59;
+    const float e = 0.14;
+    return saturate((x * (a * x + b)) / max(x * (c * x + d) + e, 1e-5));
+}
+
+float3 HablePartial(float3 x)
+{
+    const float A = 0.15;
+    const float B = 0.50;
+    const float C = 0.10;
+    const float D = 0.20;
+    const float E = 0.02;
+    const float F = 0.30;
+    return ((x * (A * x + C * B) + D * E) /
+            max(x * (A * x + B) + D * F, 1e-5)) - E / F;
+}
+
+float3 ToneMapHable(float3 x, float whitePoint)
+{
+    float3 mapped = HablePartial(x);
+    float whiteScale = max(HablePartial(float3(whitePoint, whitePoint, whitePoint)).r, 1e-5);
+    return saturate(mapped / whiteScale);
+}
+
+float3 ToneMapNeutralLuminance(float3 x, float whitePoint)
+{
+    float peak = max(x.r, max(x.g, x.b));
+    if (peak <= 1e-5)
+        return 0.0;
+
+    float mappedPeak = (peak * (1.0 + peak / max(whitePoint * whitePoint, 0.01))) /
+                       (1.0 + peak);
+    return saturate(x * (mappedPeak / peak));
+}
+
+float3 ApplyToneMapPresentationControls(float3 color, float modeContrastScale, float modeSaturationScale)
+{
+    float contrast = clamp(gToneMapContrast * modeContrastScale, 0.50, 1.60);
+    color = max((color - 0.18) * contrast + 0.18, 0.0);
+
+    float luminance = dot(color, float3(0.2126, 0.7152, 0.0722));
+    float saturation = clamp(gToneMapSaturation * modeSaturationScale, 0.0, 2.0);
+    return saturate(lerp(float3(luminance, luminance, luminance), color, saturation));
+}
+
+float3 ApplyHDRLikeToneMapping(float3 sceneColor)
+{
+    float3 x = max(sceneColor, 0.0) * max(gExposure, 0.001);
+    uint mode = min(gToneMappingMode, 6u);
+    float whitePoint = clamp(gToneMapWhitePoint, 1.0, 16.0);
+
+    if (mode == 0u)
+        return x; // exact Stable Clear v2.2 behavior; UNORM output performs the clamp
+
+    float3 mapped = 0.0;
+    float contrastScale = 1.0;
+    float saturationScale = 1.0;
+
+    if (mode == 1u)
+    {
+        mapped = ToneMapExtendedReinhard(x, whitePoint);
+        contrastScale = 0.96;
+    }
+    else if (mode == 2u)
+    {
+        mapped = ToneMapACESFitted(x);
+        saturationScale = 0.98;
+    }
+    else if (mode == 3u)
+    {
+        mapped = ToneMapHable(x, whitePoint);
+        contrastScale = 1.04;
+    }
+    else if (mode == 4u)
+    {
+        mapped = ToneMapNeutralLuminance(x, whitePoint);
+        saturationScale = 1.02;
+    }
+    else if (mode == 5u)
+    {
+        // Balanced production candidate: ACES-like shoulder with a small
+        // midtone lift while retaining highlight color and material detail.
+        mapped = ToneMapACESFitted(x * 0.92);
+        contrastScale = 1.02;
+        saturationScale = 1.00;
+    }
+    else
+    {
+        // Cinematic candidate: wider linear headroom and a stronger Hable
+        // shoulder.  It is intentionally more contrasty for clear A/B tests.
+        mapped = ToneMapHable(x * 1.18, whitePoint);
+        contrastScale = 1.10;
+        saturationScale = 0.96;
+    }
+
+    return ApplyToneMapPresentationControls(mapped, contrastScale, saturationScale);
+}
