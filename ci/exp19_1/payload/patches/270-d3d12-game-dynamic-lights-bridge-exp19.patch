+	// GAME_DYNAMIC_LIGHTS_EXP19: retain the legacy bridge defaults while
+	// exposing isolated control over game-authored transient lights.
+	const int bridgeEnabled = r_dxrGameDynamicLights ? r_dxrGameDynamicLights->integer : 1;
+	const int bridgeShadows = r_dxrGameDynamicLightShadows ? r_dxrGameDynamicLightShadows->integer : 1;
+	const int bridgeDebug = r_dxrGameDynamicLightDebug ? r_dxrGameDynamicLightDebug->integer : 0;
+	float bridgeStrength = r_dxrGameDynamicLightStrength ? r_dxrGameDynamicLightStrength->value : 1.0f;
+	float bridgeRadiusScale = r_dxrGameDynamicLightRadiusScale ? r_dxrGameDynamicLightRadiusScale->value : 1.0f;
+
+	if ( bridgeStrength < 0.0f ) bridgeStrength = 0.0f;
+	if ( bridgeStrength > 8.0f ) bridgeStrength = 8.0f;
+	if ( bridgeRadiusScale < 0.05f ) bridgeRadiusScale = 0.05f;
+	if ( bridgeRadiusScale > 4.0f ) bridgeRadiusScale = 4.0f;
+
+	static int exp19WindowStart = 0;
+	static int exp19Calls = 0;
+	static int exp19Accepted = 0;
+	static float exp19MaxSourceRadius = 0.0f;
+	static float exp19MaxSubmittedRadius = 0.0f;
+	static vec3_t exp19LastOrg = { 0.0f, 0.0f, 0.0f };
+	static vec3_t exp19LastColor = { 0.0f, 0.0f, 0.0f };
+	static int exp19LastOverdraw = 0;
+	const int exp19Now = ri.Milliseconds();
+
+	if ( exp19WindowStart == 0 ) {
+		exp19WindowStart = exp19Now;
+	}
+	exp19Calls++;
+	if ( intensity > exp19MaxSourceRadius ) exp19MaxSourceRadius = intensity;
+	VectorCopy( org, exp19LastOrg );
+	exp19LastColor[0] = r;
+	exp19LastColor[1] = g;
+	exp19LastColor[2] = b;
+	exp19LastOverdraw = overdraw;
+
+	if ( bridgeEnabled && bridgeStrength > 0.0f ) {
+		const float submittedRadius = intensity * bridgeRadiusScale;
+		glRaytracingLight_t light = glRaytracingLightingMakePointLight(
+			org[0], org[1], org[2], submittedRadius,
+			r, g, b, bridgeStrength );
+		// Point lights use samples==0 only as the Experiment 19 shadow-off bit.
+		light.samples = bridgeShadows ? 1u : 0u;
+		if ( glRaytracingLightingAddLight( &light ) ) {
+			exp19Accepted++;
+			if ( submittedRadius > exp19MaxSubmittedRadius ) exp19MaxSubmittedRadius = submittedRadius;
+		}
+	}
+
+	if ( bridgeDebug && exp19Now - exp19WindowStart >= 1000 ) {
+		ri.Printf( PRINT_ALL,
+			"GAME_DYNAMIC_LIGHTS_EXP19 enabled=%d calls=%d accepted=%d strength=%.3f radiusScale=%.3f shadows=%d maxSourceRadius=%.3f maxSubmittedRadius=%.3f lastOrg=(%.2f %.2f %.2f) lastColor=(%.3f %.3f %.3f) lastOverdraw=%d\n",
+			bridgeEnabled ? 1 : 0, exp19Calls, exp19Accepted,
+			bridgeStrength, bridgeRadiusScale, bridgeShadows ? 1 : 0,
+			exp19MaxSourceRadius, exp19MaxSubmittedRadius,
+			exp19LastOrg[0], exp19LastOrg[1], exp19LastOrg[2],
+			exp19LastColor[0], exp19LastColor[1], exp19LastColor[2],
+			exp19LastOverdraw );
+		exp19WindowStart = exp19Now;
+		exp19Calls = 0;
+		exp19Accepted = 0;
+		exp19MaxSourceRadius = 0.0f;
+		exp19MaxSubmittedRadius = 0.0f;
+	}
 #if 0
