 R"(
+float ComputeLinearFogAmount(float distanceToCamera, float startDistance, float endDistance)
+{
+    float span = max(endDistance - startDistance, 1.0);
+    return saturate((distanceToCamera - startDistance) / span);
+}
+
+float ComputeMapFogAmount(float distanceToCamera)
+{
+    float startDistance = gMapFogParams.x;
+    float endDistance = gMapFogParams.y;
+    float density = max(gMapFogParams.z, 0.0);
+
+    if (gMapFogMode == 1u)
+    {
+        return ComputeLinearFogAmount(distanceToCamera, startDistance, endDistance);
+    }
+    if (gMapFogMode == 2u)
+    {
+        return saturate(1.0 - exp(-density * distanceToCamera));
+    }
+    if (gMapFogMode == 3u)
+    {
+        float d = density * distanceToCamera;
+        return saturate(1.0 - exp(-(d * d)));
+    }
+    return 0.0;
+}
+
+float3 ApplyDXRAtmosphere(float3 color, float3 worldPos)
+{
+    uint mode = min(gAtmosphereMode, 6u);
+    if (mode == 0u)
+        return color;
+
+    float distanceToCamera = length(worldPos - gCameraPos.xyz);
+    float fogAmount = 0.0;
+    float3 fogColor = float3(0.18, 0.20, 0.22);
+
+    if (mode == 1u)
+    {
+        fogAmount = ComputeMapFogAmount(distanceToCamera);
+        fogColor = gMapFogColor.rgb;
+    }
+    else if (mode == 2u)
+    {
+        if (gMapFogMode != 0u)
+        {
+            fogAmount = ComputeMapFogAmount(distanceToCamera);
+            fogColor = gMapFogColor.rgb;
+        }
+        else
+        {
+            fogAmount = ComputeLinearFogAmount(distanceToCamera, 550.0, 2600.0) * 0.48;
+            fogColor = float3(0.17, 0.19, 0.21);
+        }
+    }
+    else if (mode == 3u)
+    {
+        fogAmount = ComputeLinearFogAmount(distanceToCamera, 220.0, 1500.0) * 0.72;
+        fogColor = float3(0.15, 0.19, 0.24);
+    }
+    else if (mode == 4u)
+    {
+        fogAmount = ComputeLinearFogAmount(distanceToCamera, 160.0, 1200.0) * 0.60;
+        fogColor = float3(0.27, 0.21, 0.15);
+    }
+    else if (mode == 5u)
+    {
+        float distanceFog = ComputeLinearFogAmount(distanceToCamera, 180.0, 1700.0);
+        float belowCamera = saturate((gCameraPos.z - worldPos.z + 48.0) / 320.0);
+        float lowLayer = smoothstep(0.05, 0.95, belowCamera);
+        fogAmount = saturate(distanceFog * 0.28 + lowLayer * 0.52);
+        fogColor = float3(0.18, 0.22, 0.24);
+    }
+    else
+    {
+        float distanceFog = ComputeLinearFogAmount(distanceToCamera, 100.0, 1250.0);
+        float belowCamera = saturate((gCameraPos.z - worldPos.z + 32.0) / 420.0);
+        float layer = smoothstep(0.0, 1.0, belowCamera);
+        fogAmount = saturate(distanceFog * 0.58 + layer * 0.28);
+        fogColor = float3(0.13, 0.17, 0.21);
+    }
+
+    fogAmount = min(saturate(fogAmount), 0.90);
+    return lerp(color, fogColor, fogAmount);
+}
