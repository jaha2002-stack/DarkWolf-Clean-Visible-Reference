+void glRaytracingLightingSetAtmosphereOptions(
+	uint32_t atmosphereMode,
+	uint32_t mapFogMode,
+	float fogR,
+	float fogG,
+	float fogB,
+	float fogStart,
+	float fogEnd,
+	float fogDensity)
+{
+	g_glRaytracingLighting.constants.atmosphereMode = glRaytracingClamp<uint32_t>(atmosphereMode, 0u, 6u);
+	g_glRaytracingLighting.constants.mapFogMode = glRaytracingClamp<uint32_t>(mapFogMode, 0u, 3u);
+	g_glRaytracingLighting.constants.mapFogColor[0] = glRaytracingClamp<float>(fogR, 0.0f, 4.0f);
+	g_glRaytracingLighting.constants.mapFogColor[1] = glRaytracingClamp<float>(fogG, 0.0f, 4.0f);
+	g_glRaytracingLighting.constants.mapFogColor[2] = glRaytracingClamp<float>(fogB, 0.0f, 4.0f);
+	g_glRaytracingLighting.constants.mapFogColor[3] = 1.0f;
+	g_glRaytracingLighting.constants.mapFogParams[0] = fogStart;
+	g_glRaytracingLighting.constants.mapFogParams[1] = (fogEnd > fogStart + 1.0f) ? fogEnd : (fogStart + 1.0f);
+	g_glRaytracingLighting.constants.mapFogParams[2] = (fogDensity > 0.0f) ? fogDensity : 0.0f;
+	g_glRaytracingLighting.constants.mapFogParams[3] = 0.0f;
+	glRaytracingLightingUpdateConstants();
+}
