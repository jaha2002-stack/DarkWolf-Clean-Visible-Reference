+R"(
+float3 ComputeRoughnessOnlyGGXSpecular(
+    float3 N, float3 V, float3 L, float3 lightColor,
+    float lightIntensity, float atten, float shadow, float3 baseAlbedo,
+    float surfaceRoughness)
+{
+    float3 H = normalize(V + L);
+    float NdotL = saturate(dot(N, L));
+    float NdotV = saturate(dot(N, V));
+    float NdotH = saturate(dot(N, H));
+    float VdotH = saturate(dot(V, H));
+    if (NdotL <= 0.0 || NdotV <= 0.0)
+        return 0.0;
+
+    float roughness = clamp(surfaceRoughness, 0.08, 0.99);
+    float alpha = roughness * roughness;
+    float alpha2 = alpha * alpha;
+    float denom = NdotH * NdotH * (alpha2 - 1.0) + 1.0;
+    float D = alpha2 / max(3.14159265 * denom * denom, 1e-5);
+    float k = roughness + 1.0;
+    k = (k * k) * 0.125;
+    float Gv = NdotV / max(NdotV * (1.0 - k) + k, 1e-5);
+    float Gl = NdotL / max(NdotL * (1.0 - k) + k, 1e-5);
+    float metalHint = saturate((max(max(baseAlbedo.r, baseAlbedo.g), baseAlbedo.b) - 0.75) * 1.5);
+    float3 F0 = lerp(float3(0.04, 0.04, 0.04), baseAlbedo, metalHint);
+    float3 F = F0 + (1.0 - F0) * pow(1.0 - VdotH, 5.0);
+    float3 brdf = (D * Gv * Gl * F) / max(4.0 * NdotV * NdotL, 1e-4);
+    brdf = min(brdf * 0.60, 2.5);
+    return lightColor * (lightIntensity * atten * shadow * NdotL) * brdf;
+}
+
+float3 MaterialF0(uint materialType, float3 baseAlbedo)
+{
+    if (materialType == DXR_MATERIAL_METAL)
+        return saturate(baseAlbedo * 0.78 + 0.10);
+    if (materialType == DXR_MATERIAL_WEAPON)
+        return saturate(baseAlbedo * 0.58 + 0.12);
+    if (materialType == DXR_MATERIAL_GLASS)
+        return float3(0.075, 0.075, 0.075);
+    if (materialType == DXR_MATERIAL_CERAMIC)
+        return float3(0.050, 0.050, 0.050);
+    if (materialType == DXR_MATERIAL_STONE || materialType == DXR_MATERIAL_RUBBLE)
+        return float3(0.022, 0.022, 0.022);
+    if (materialType == DXR_MATERIAL_WOOD)
+        return float3(0.028, 0.025, 0.022);
+    if (materialType == DXR_MATERIAL_SNOW)
+        return float3(0.020, 0.020, 0.020);
+    if (materialType == DXR_MATERIAL_ORGANIC)
+        return float3(0.018, 0.018, 0.018);
+    if (materialType == DXR_MATERIAL_SOFT)
+        return float3(0.012, 0.012, 0.012);
+    return float3(0.035, 0.035, 0.035);
+}
+
+float MaterialSpecularScale(uint materialType, bool strictMode)
+{
+    float scale = 0.34;
+    if (materialType == DXR_MATERIAL_METAL) scale = 1.00;
+    else if (materialType == DXR_MATERIAL_WEAPON) scale = 0.82;
+    else if (materialType == DXR_MATERIAL_GLASS) scale = 0.78;
+    else if (materialType == DXR_MATERIAL_CERAMIC) scale = 0.32;
+    else if (materialType == DXR_MATERIAL_WOOD) scale = 0.16;
+    else if (materialType == DXR_MATERIAL_STONE) scale = 0.11;
+    else if (materialType == DXR_MATERIAL_RUBBLE) scale = 0.07;
+    else if (materialType == DXR_MATERIAL_SNOW) scale = 0.09;
+    else if (materialType == DXR_MATERIAL_ORGANIC) scale = 0.055;
+    else if (materialType == DXR_MATERIAL_SOFT) scale = 0.025;
+
+    if (strictMode && materialType != DXR_MATERIAL_METAL &&
+        materialType != DXR_MATERIAL_WEAPON && materialType != DXR_MATERIAL_GLASS)
+    {
+        scale *= 0.55;
+    }
+    return scale;
+}
+
+float3 ComputeMaterialGGXSpecular(
+    float3 N, float3 V, float3 L, float3 lightColor,
+    float lightIntensity, float atten, float shadow, float3 baseAlbedo,
+    float surfaceRoughness, uint materialType, bool strictMode)
+{
+    float3 H = normalize(V + L);
+    float NdotL = saturate(dot(N, L));
+    float NdotV = saturate(dot(N, V));
+    float NdotH = saturate(dot(N, H));
+    float VdotH = saturate(dot(V, H));
+    if (NdotL <= 0.0 || NdotV <= 0.0)
+        return 0.0;
+
+    float roughness = clamp(surfaceRoughness, 0.08, 0.99);
+    if (strictMode && materialType != DXR_MATERIAL_METAL &&
+        materialType != DXR_MATERIAL_WEAPON && materialType != DXR_MATERIAL_GLASS)
+    {
+        roughness = min(0.99, roughness + 0.08);
+    }
+
+    float alpha = roughness * roughness;
+    float alpha2 = alpha * alpha;
+    float denom = NdotH * NdotH * (alpha2 - 1.0) + 1.0;
+    float D = alpha2 / max(3.14159265 * denom * denom, 1e-5);
+
+    float k = (roughness + 1.0);
+    k = (k * k) * 0.125;
+    float Gv = NdotV / max(NdotV * (1.0 - k) + k, 1e-5);
+    float Gl = NdotL / max(NdotL * (1.0 - k) + k, 1e-5);
+    float G = Gv * Gl;
+
+    float3 F0 = MaterialF0(materialType, baseAlbedo);
+    float3 F = F0 + (1.0 - F0) * pow(1.0 - VdotH, 5.0);
+    float3 brdf = (D * G * F) / max(4.0 * NdotV * NdotL, 1e-4);
+    brdf *= MaterialSpecularScale(materialType, strictMode);
+    brdf = min(brdf, 2.5);
 
+    return lightColor * (lightIntensity * atten * shadow * NdotL) * brdf;
+}
+
