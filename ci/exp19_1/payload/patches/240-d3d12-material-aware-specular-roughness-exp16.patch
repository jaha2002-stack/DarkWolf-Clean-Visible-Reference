+R"(
+float3 ComputeMaterialBlinnSpecular(
+    float3 N, float3 V, float3 L, float3 lightColor,
+    float lightIntensity, float atten, float shadow, float3 baseAlbedo, uint materialType)
+{
+    float3 H = normalize(V + L);
+    float NdotL = saturate(dot(N, L));
+    float NdotV = saturate(dot(N, V));
+    float NdotH = saturate(dot(N, H));
+    float VdotH = saturate(dot(V, H));
+    if (NdotL <= 0.0 || NdotV <= 0.0)
+        return 0.0;
+
+    float shininess = 48.0;
+    float specPow = pow(NdotH, shininess);
+    float3 F0 = MaterialF0(materialType, baseAlbedo);
+    float3 fresnel = F0 + (1.0 - F0) * pow(1.0 - VdotH, 5.0);
+    float3 spec = fresnel * specPow * ((shininess + 8.0) * 0.125);
+    spec *= MaterialSpecularScale(materialType, false);
     return lightColor * (lightIntensity * atten * shadow * NdotL) * spec;
 }
+
+float3 ComputeSpecular(
+    float3 N, float3 V, float3 L, float3 lightColor,
+    float lightIntensity, float atten, float shadow, float3 baseAlbedo,
+    float surfaceRoughness, uint materialType, float geoFlag)
+{
+    if (gEnableSpecular == 0)
+        return 0.0;
+
+    if (gMaterialSpecularMode == 0u)
+    {
+        return ComputeLegacySpecular(
+            N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo);
+    }
+
+    if (gMaterialSpecularMode == 1u)
+    {
+        // Roughness-channel A/B: keep the old albedo-based metal guess, but
+        // replace the fixed shininess with the per-surface roughness carried
+        // by the G-buffer.
+        return ComputeRoughnessOnlyGGXSpecular(
+            N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo,
+            surfaceRoughness);
+    }
+
+    if (gMaterialSpecularMode == 2u)
+    {
+        // Isolate the bad albedo-brightness metal guess: retain the old lobe
+        // shape while replacing F0 and intensity with RTCW material classes.
+        return ComputeMaterialBlinnSpecular(
+            N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo, materialType);
+    }
+
+    bool organicPixel = (materialType == DXR_MATERIAL_ORGANIC) ||
+                        ((uint)(geoFlag + 0.5) == GEOMETRY_FLAG_SKELETAL &&
+                         materialType != DXR_MATERIAL_WEAPON);
+
+    if (gMaterialSpecularMode == 3u && !organicPixel)
+    {
+        // Character-only A/B: leave the world on the exact legacy response.
+        return ComputeLegacySpecular(
+            N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo);
+    }
+    if (gMaterialSpecularMode == 4u && organicPixel)
+    {
+        // World-only A/B: leave characters on the exact legacy response.
+        return ComputeLegacySpecular(
+            N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo);
+    }
+
+    bool strictMode = (gMaterialSpecularMode == 6u);
+    return ComputeMaterialGGXSpecular(
+        N, V, L, lightColor, lightIntensity, atten, shadow, baseAlbedo,
+        surfaceRoughness, materialType, strictMode);
+}
