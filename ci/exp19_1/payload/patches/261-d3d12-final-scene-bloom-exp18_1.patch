+// Bloom 18.1 intentionally reads the final native SDR scene. This captures
+// alpha-blended fire, smoke, muzzle flashes and explosions rendered after DXR.
+static const char* kQD3D12FinalBloomHLSL = R"HLSL(
+Texture2D<float4> gInput : register(t0);
+SamplerState gLinearClamp : register(s0);
+
+cbuffer BloomParams : register(b0)
+{
+    float4 gP0; // x/y texel size, z threshold or direction.x, w softKnee or direction.y
+    float4 gP1; // x radius, y final strength, z diagnostic scale, w reserved
+};
+
+struct VSOut
+{
+    float4 pos : SV_Position;
+    float2 uv  : TEXCOORD0;
+};
+
+float3 ExtractBloom(float3 color, float threshold, float softKnee)
+{
+    float brightness = max(color.r, max(color.g, color.b));
+    float knee = max(threshold * saturate(softKnee), 1e-4);
+    float soft = clamp(brightness - threshold + knee, 0.0, 2.0 * knee);
+    soft = soft * soft / (4.0 * knee + 1e-4);
+    float contribution = max(brightness - threshold, soft) / max(brightness, 1e-4);
+    return max(color * contribution, 0.0);
+}
+
+float4 PSBright(VSOut i) : SV_Target0
+{
+    float2 t = gP0.xy;
+    float3 c = 0.25 * (
+        gInput.Sample(gLinearClamp, i.uv + t * float2(-0.5, -0.5)).rgb +
+        gInput.Sample(gLinearClamp, i.uv + t * float2( 0.5, -0.5)).rgb +
+        gInput.Sample(gLinearClamp, i.uv + t * float2(-0.5,  0.5)).rgb +
+        gInput.Sample(gLinearClamp, i.uv + t * float2( 0.5,  0.5)).rgb);
+    return float4(ExtractBloom(c, gP0.z, gP0.w) * max(gP1.z, 1.0), 1.0);
+}
+
+float4 PSBlur(VSOut i) : SV_Target0
+{
+    float2 texel = gP0.xy;
+    float2 direction = gP0.zw;
+    float radius = max(gP1.x, 0.5);
+    float2 stepUv = texel * direction * radius;
+
+    float3 result = gInput.Sample(gLinearClamp, i.uv).rgb * 0.2270270270;
+    result += gInput.Sample(gLinearClamp, i.uv + stepUv * 1.3846153846).rgb * 0.3162162162;
+    result += gInput.Sample(gLinearClamp, i.uv - stepUv * 1.3846153846).rgb * 0.3162162162;
+    result += gInput.Sample(gLinearClamp, i.uv + stepUv * 3.2307692308).rgb * 0.0702702703;
+    result += gInput.Sample(gLinearClamp, i.uv - stepUv * 3.2307692308).rgb * 0.0702702703;
+    return float4(result * max(gP1.y, 0.0), 1.0);
+}
+)HLSL";
