+
+static uint32_t QD3D12_FinalBloomFloatBits(float value)
+{
+    uint32_t bits = 0;
+    memcpy(&bits, &value, sizeof(bits));
+    return bits;
+}
+
+static void QD3D12_EnsureFinalBloomResources(QD3D12Window& w)
+{
+    const UINT width = std::max<UINT>(w.width, 1u);
+    const UINT height = std::max<UINT>(w.height, 1u);
+    const UINT downWidth = std::max<UINT>((width + 3u) / 4u, 1u);
+    const UINT downHeight = std::max<UINT>((height + 3u) / 4u, 1u);
+    if (w.finalBloomSceneCopy && w.finalBloomWidth == width && w.finalBloomHeight == height &&
+        w.finalBloomDownWidth == downWidth && w.finalBloomDownHeight == downHeight)
+    {
+        return;
+    }
+
+    w.finalBloomSceneCopy.Reset();
+    w.finalBloomBright.Reset();
+    w.finalBloomBlurA.Reset();
+    w.finalBloomBlurB.Reset();
+    w.finalBloomRtvHeap.Reset();
+
+    D3D12_HEAP_PROPERTIES hp{};
+    hp.Type = D3D12_HEAP_TYPE_DEFAULT;
+
+    auto createTexture = [&](ComPtr<ID3D12Resource>& out, D3D12_RESOURCE_STATES& state,
+        UINT texWidth, UINT texHeight, DXGI_FORMAT format, D3D12_RESOURCE_FLAGS flags,
+        D3D12_RESOURCE_STATES initialState)
+    {
+        D3D12_RESOURCE_DESC rd{};
+        rd.Dimension = D3D12_RESOURCE_DIMENSION_TEXTURE2D;
+        rd.Width = texWidth;
+        rd.Height = texHeight;
+        rd.DepthOrArraySize = 1;
+        rd.MipLevels = 1;
+        rd.Format = format;
+        rd.SampleDesc.Count = 1;
+        rd.Layout = D3D12_TEXTURE_LAYOUT_UNKNOWN;
+        rd.Flags = flags;
+        QD3D12_CHECK(g_gl.device->CreateCommittedResource(
+            &hp, D3D12_HEAP_FLAG_NONE, &rd, initialState, nullptr, IID_PPV_ARGS(&out)));
+        state = initialState;
+    };
+
+    createTexture(w.finalBloomSceneCopy, w.finalBloomSceneCopyState,
+        width, height, QD3D12_SceneColorFormat, D3D12_RESOURCE_FLAG_NONE,
+        D3D12_RESOURCE_STATE_COPY_DEST);
+    createTexture(w.finalBloomBright, w.finalBloomBrightState,
+        downWidth, downHeight, DXGI_FORMAT_R16G16B16A16_FLOAT,
+        D3D12_RESOURCE_FLAG_ALLOW_RENDER_TARGET, D3D12_RESOURCE_STATE_RENDER_TARGET);
+    createTexture(w.finalBloomBlurA, w.finalBloomBlurAState,
+        downWidth, downHeight, DXGI_FORMAT_R16G16B16A16_FLOAT,
+        D3D12_RESOURCE_FLAG_ALLOW_RENDER_TARGET, D3D12_RESOURCE_STATE_RENDER_TARGET);
+    createTexture(w.finalBloomBlurB, w.finalBloomBlurBState,
+        downWidth, downHeight, DXGI_FORMAT_R16G16B16A16_FLOAT,
+        D3D12_RESOURCE_FLAG_ALLOW_RENDER_TARGET, D3D12_RESOURCE_STATE_RENDER_TARGET);
+
+    D3D12_DESCRIPTOR_HEAP_DESC rtvDesc{};
+    rtvDesc.NumDescriptors = 3;
+    rtvDesc.Type = D3D12_DESCRIPTOR_HEAP_TYPE_RTV;
+    QD3D12_CHECK(g_gl.device->CreateDescriptorHeap(&rtvDesc, IID_PPV_ARGS(&w.finalBloomRtvHeap)));
+    w.finalBloomRtvStride = g_gl.device->GetDescriptorHandleIncrementSize(D3D12_DESCRIPTOR_HEAP_TYPE_RTV);
+    D3D12_CPU_DESCRIPTOR_HANDLE rtv = w.finalBloomRtvHeap->GetCPUDescriptorHandleForHeapStart();
+    w.finalBloomBrightRtv = rtv;
+    g_gl.device->CreateRenderTargetView(w.finalBloomBright.Get(), nullptr, rtv);
+    rtv.ptr += w.finalBloomRtvStride;
+    w.finalBloomBlurARtv = rtv;
+    g_gl.device->CreateRenderTargetView(w.finalBloomBlurA.Get(), nullptr, rtv);
+    rtv.ptr += w.finalBloomRtvStride;
+    w.finalBloomBlurBRtv = rtv;
+    g_gl.device->CreateRenderTargetView(w.finalBloomBlurB.Get(), nullptr, rtv);
+
+    auto createSrv = [&](ID3D12Resource* resource, DXGI_FORMAT format, UINT& index,
+        D3D12_CPU_DESCRIPTOR_HANDLE& cpu, D3D12_GPU_DESCRIPTOR_HANDLE& gpu)
+    {
+        if (index == UINT_MAX)
+        {
+            index = g_gl.nextSrvIndex++;
+            cpu = QD3D12_SrvCpu(index);
+            gpu = QD3D12_SrvGpu(index);
+        }
+        D3D12_SHADER_RESOURCE_VIEW_DESC sd{};
+        sd.ViewDimension = D3D12_SRV_DIMENSION_TEXTURE2D;
+        sd.Format = format;
+        sd.Shader4ComponentMapping = D3D12_DEFAULT_SHADER_4_COMPONENT_MAPPING;
+        sd.Texture2D.MipLevels = 1;
+        g_gl.device->CreateShaderResourceView(resource, &sd, cpu);
+    };
+
+    createSrv(w.finalBloomSceneCopy.Get(), QD3D12_SceneColorFormat,
+        w.finalBloomSceneCopySrvIndex, w.finalBloomSceneCopySrvCpu, w.finalBloomSceneCopySrvGpu);
+    createSrv(w.finalBloomBright.Get(), DXGI_FORMAT_R16G16B16A16_FLOAT,
+        w.finalBloomBrightSrvIndex, w.finalBloomBrightSrvCpu, w.finalBloomBrightSrvGpu);
+    createSrv(w.finalBloomBlurA.Get(), DXGI_FORMAT_R16G16B16A16_FLOAT,
+        w.finalBloomBlurASrvIndex, w.finalBloomBlurASrvCpu, w.finalBloomBlurASrvGpu);
+    createSrv(w.finalBloomBlurB.Get(), DXGI_FORMAT_R16G16B16A16_FLOAT,
+        w.finalBloomBlurBSrvIndex, w.finalBloomBlurBSrvCpu, w.finalBloomBlurBSrvGpu);
+
+    w.finalBloomWidth = width;
+    w.finalBloomHeight = height;
+    w.finalBloomDownWidth = downWidth;
+    w.finalBloomDownHeight = downHeight;
+}
+
+static void QD3D12_FinalBloomPass(ID3D12GraphicsCommandList* cl,
+    ID3D12PipelineState* pso, D3D12_GPU_DESCRIPTOR_HANDLE inputSrv,
+    D3D12_CPU_DESCRIPTOR_HANDLE outputRtv, const D3D12_VIEWPORT& viewport,
+    const D3D12_RECT& scissor, const float params[8])
+{
+    ID3D12DescriptorHeap* heaps[] = { g_gl.srvHeap.Get() };
+    cl->SetDescriptorHeaps(_countof(heaps), heaps);
+    cl->SetGraphicsRootSignature(g_gl.finalBloomRootSig.Get());
+    cl->SetPipelineState(pso);
+    cl->OMSetRenderTargets(1, &outputRtv, FALSE, nullptr);
+    cl->RSSetViewports(1, &viewport);
+    cl->RSSetScissorRects(1, &scissor);
+    cl->IASetPrimitiveTopology(D3D_PRIMITIVE_TOPOLOGY_TRIANGLELIST);
+    cl->SetGraphicsRootDescriptorTable(0, inputSrv);
+    uint32_t bits[8];
+    for (int i = 0; i < 8; ++i)
+        bits[i] = QD3D12_FinalBloomFloatBits(params[i]);
+    cl->SetGraphicsRoot32BitConstants(1, 8, bits, 0);
+    cl->DrawInstanced(3, 1, 0, 0);
+}
+
+void glFinalSceneBloomSetOptions(uint32_t mode, float threshold, float strength, float radius, float softKnee)
+{
+    g_gl.finalBloomMode = std::min<uint32_t>(mode, 6u);
+    g_gl.finalBloomThreshold = ClampValue<float>(threshold, 0.05f, 1.50f);
+    g_gl.finalBloomStrength = ClampValue<float>(strength, 0.0f, 2.0f);
+    g_gl.finalBloomRadius = ClampValue<float>(radius, 1.0f, 48.0f);
+    g_gl.finalBloomSoftKnee = ClampValue<float>(softKnee, 0.0f, 1.0f);
+}
+
+void glFinalSceneBloomApply(void)
+{
+    if (g_gl.finalBloomAppliedThisFrame)
+        return;
+    if (g_gl.finalBloomMode == 0u || !g_currentWindow || !g_gl.device || !g_gl.cmdList)
+        return;
+    if (!g_gl.sceneResolvedThisFrame || g_gl.framePhase != QD3D12_FRAME_NATIVE_POST_UPSCALE)
+        return;
+    g_gl.finalBloomAppliedThisFrame = true;
+
+    QD3D12_EnsureFrameOpen();
+    QD3D12_FlushQueuedBatches();
+
+    QD3D12Window& w = *g_currentWindow;
+    QD3D12_EnsureFinalBloomResources(w);
+    ID3D12GraphicsCommandList* cl = g_gl.cmdList.Get();
+    ID3D12Resource* backBuffer = w.backBuffers[w.frameIndex].Get();
+    if (!backBuffer || !w.finalBloomSceneCopy || !w.finalBloomBright || !w.finalBloomBlurA || !w.finalBloomBlurB)
+        return;
+
+    QD3D12_TransitionResource(cl, backBuffer, w.backBufferState[w.frameIndex], D3D12_RESOURCE_STATE_COPY_SOURCE);
+    QD3D12_TransitionResource(cl, w.finalBloomSceneCopy.Get(), w.finalBloomSceneCopyState, D3D12_RESOURCE_STATE_COPY_DEST);
+    cl->CopyResource(w.finalBloomSceneCopy.Get(), backBuffer);
+    QD3D12_TransitionResource(cl, w.finalBloomSceneCopy.Get(), w.finalBloomSceneCopyState, D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE);
+    QD3D12_TransitionResource(cl, backBuffer, w.backBufferState[w.frameIndex], D3D12_RESOURCE_STATE_RENDER_TARGET);
+
+    D3D12_VIEWPORT downViewport{};
+    downViewport.Width = (float)w.finalBloomDownWidth;
+    downViewport.Height = (float)w.finalBloomDownHeight;
+    downViewport.MinDepth = 0.0f;
+    downViewport.MaxDepth = 1.0f;
+    D3D12_RECT downScissor{ 0, 0, (LONG)w.finalBloomDownWidth, (LONG)w.finalBloomDownHeight };
+
+    const float diagnosticScale = (g_gl.finalBloomMode == 1u) ? 3.0f : 1.0f;
+    float brightParams[8] = {
+        1.0f / (float)w.finalBloomWidth, 1.0f / (float)w.finalBloomHeight,
+        g_gl.finalBloomThreshold, g_gl.finalBloomSoftKnee,
+        0.0f, 0.0f, diagnosticScale, 0.0f
+    };
+    QD3D12_TransitionResource(cl, w.finalBloomBright.Get(), w.finalBloomBrightState, D3D12_RESOURCE_STATE_RENDER_TARGET);
+    QD3D12_FinalBloomPass(cl, g_gl.finalBloomBrightPSO.Get(), w.finalBloomSceneCopySrvGpu,
+        w.finalBloomBrightRtv, downViewport, downScissor, brightParams);
+    QD3D12_TransitionResource(cl, w.finalBloomBright.Get(), w.finalBloomBrightState, D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE);
+
+    const float quarterRadius = (std::max)(g_gl.finalBloomRadius * 0.25f, 0.5f);
+    float blurH[8] = {
+        1.0f / (float)w.finalBloomDownWidth, 1.0f / (float)w.finalBloomDownHeight,
+        1.0f, 0.0f, quarterRadius, 1.0f, 0.0f, 0.0f
+    };
+    QD3D12_TransitionResource(cl, w.finalBloomBlurA.Get(), w.finalBloomBlurAState, D3D12_RESOURCE_STATE_RENDER_TARGET);
+    QD3D12_FinalBloomPass(cl, g_gl.finalBloomBlurPSO.Get(), w.finalBloomBrightSrvGpu,
+        w.finalBloomBlurARtv, downViewport, downScissor, blurH);
+    QD3D12_TransitionResource(cl, w.finalBloomBlurA.Get(), w.finalBloomBlurAState, D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE);
+
+    float blurV[8] = {
+        1.0f / (float)w.finalBloomDownWidth, 1.0f / (float)w.finalBloomDownHeight,
+        0.0f, 1.0f, quarterRadius, g_gl.finalBloomStrength, 0.0f, 0.0f
+    };
+    QD3D12_TransitionResource(cl, w.finalBloomBlurB.Get(), w.finalBloomBlurBState, D3D12_RESOURCE_STATE_RENDER_TARGET);
+    QD3D12_FinalBloomPass(cl, g_gl.finalBloomBlurPSO.Get(), w.finalBloomBlurASrvGpu,
+        w.finalBloomBlurBRtv, downViewport, downScissor, blurV);
+    QD3D12_TransitionResource(cl, w.finalBloomBlurB.Get(), w.finalBloomBlurBState, D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE);
+
+    D3D12_VIEWPORT fullViewport{};
+    fullViewport.Width = (float)w.width;
+    fullViewport.Height = (float)w.height;
+    fullViewport.MinDepth = 0.0f;
+    fullViewport.MaxDepth = 1.0f;
+    D3D12_RECT fullScissor{ 0, 0, (LONG)w.width, (LONG)w.height };
+
+    if (g_gl.finalBloomMode == 1u)
+    {
+        QD3D12_PostFullscreenPass(cl, g_gl.postCopyPSO.Get(), w.finalBloomBrightSrvGpu,
+            CurrentBackBufferRTV(), fullViewport, fullScissor);
+    }
+    else if (g_gl.finalBloomMode == 2u)
+    {
+        QD3D12_PostFullscreenPass(cl, g_gl.postCopyPSO.Get(), w.finalBloomBlurBSrvGpu,
+            CurrentBackBufferRTV(), fullViewport, fullScissor);
+    }
+    else
+    {
+        QD3D12_PostFullscreenPass(cl, g_gl.postCopyPSO.Get(), w.finalBloomSceneCopySrvGpu,
+            CurrentBackBufferRTV(), fullViewport, fullScissor);
+        QD3D12_PostFullscreenPass(cl, g_gl.postAdditivePSO.Get(), w.finalBloomBlurBSrvGpu,
+            CurrentBackBufferRTV(), fullViewport, fullScissor);
+    }
+
+    QD3D12_BindTargetsForCurrentPhase(w);
+}
