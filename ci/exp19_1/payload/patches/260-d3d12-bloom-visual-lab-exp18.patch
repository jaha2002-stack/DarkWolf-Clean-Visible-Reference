+
+float3 ToneMapExtendedReinhard(float3 x, float whitePoint)
+{
+    float white2 = max(whitePoint * whitePoint, 1e-4);
+    return (x * (1.0 + x / white2)) / (1.0 + x);
+}
+
+float3 ToneMapACESFitted(float3 x)
+{
+    const float a = 2.51;
+    const float b = 0.03;
+    const float c = 2.43;
+    const float d = 0.59;
+    const float e = 0.14;
+    return saturate((x * (a * x + b)) / (x * (c * x + d) + e));
+}
+
+float3 HablePartial(float3 x)
+{
+    const float A = 0.15;
+    const float B = 0.50;
+    const float C = 0.10;
+    const float D = 0.20;
+    const float E = 0.02;
+    const float F = 0.30;
+    return ((x * (A * x + C * B) + D * E) /
+            (x * (A * x + B) + D * F)) - E / F;
+}
+
+float3 ToneMapHable(float3 x, float whitePoint)
+{
+    float3 mapped = HablePartial(x * 2.0);
+    float3 whiteScale = 1.0 / max(HablePartial(float3(whitePoint, whitePoint, whitePoint)), 1e-4);
+    return saturate(mapped * whiteScale);
+}
+
+float3 ToneMapNeutralLuminance(float3 x, float whitePoint)
+{
+    float lum = dot(x, float3(0.2126, 0.7152, 0.0722));
+    if (lum <= 1e-5)
+        return 0.0;
+    float mappedLum = (lum * (1.0 + lum / max(whitePoint * whitePoint, 1e-4))) / (1.0 + lum);
+    return saturate(x * (mappedLum / lum));
+}
+
+float3 ApplyToneMapPresentationControls(float3 color, float modeContrastScale, float modeSaturationScale)
+{
+    float contrast = clamp(gToneMapContrast * modeContrastScale, 0.50, 1.60);
+    color = saturate((color - 0.18) * contrast + 0.18);
+    float lum = dot(color, float3(0.2126, 0.7152, 0.0722));
+    float saturation = clamp(gToneMapSaturation * modeSaturationScale, 0.0, 2.0);
+    return saturate(lerp(lum.xxx, color, saturation));
+}
+
+float3 ApplyHDRLikeToneMapping(float3 sceneColor)
+{
+    float3 x = max(sceneColor, 0.0) * max(gExposure, 0.0);
+    uint mode = min(gToneMappingMode, 6u);
+    float whitePoint = clamp(gToneMapWhitePoint, 1.0, 16.0);
+    if (mode == 0u)
+        return saturate(x);
+
+    float3 mapped = 0.0;
+    float contrastScale = 1.0;
+    float saturationScale = 1.0;
+    if (mode == 1u)
+        mapped = ToneMapExtendedReinhard(x, whitePoint);
+    else if (mode == 2u)
+    {
+        mapped = ToneMapACESFitted(x);
+        saturationScale = 1.03;
+    }
+    else if (mode == 3u)
+    {
+        mapped = ToneMapHable(x, whitePoint);
+        contrastScale = 1.05;
+    }
+    else if (mode == 4u)
+        mapped = ToneMapNeutralLuminance(x, whitePoint);
+    else if (mode == 5u)
+    {
+        mapped = ToneMapACESFitted(x * 0.92);
+        contrastScale = 1.02;
+        saturationScale = 1.01;
+    }
+    else
+    {
+        mapped = ToneMapHable(x * 1.18, whitePoint);
+        contrastScale = 1.12;
+        saturationScale = 1.06;
+    }
+    return ApplyToneMapPresentationControls(mapped, contrastScale, saturationScale);
+}
+
+float3 LoadHdrClamped(int2 p)
+{
+    int2 maxPixel = int2((int)gScreenSize.x - 1, (int)gScreenSize.y - 1);
+    return gHdrScene.Load(int3(clamp(p, int2(0, 0), maxPixel), 0)).rgb;
+}
+
+float3 ExtractBloom(float3 color, float threshold, float softKnee)
+{
+    float brightness = max(color.r, max(color.g, color.b));
+    float knee = max(threshold * clamp(softKnee, 0.0, 1.0), 1e-4);
+    float soft = clamp(brightness - threshold + knee, 0.0, 2.0 * knee);
+    soft = soft * soft / (4.0 * knee + 1e-4);
+    float contribution = max(brightness - threshold, soft) / max(brightness, 1e-4);
+    return color * max(contribution, 0.0);
+}
+
+float3 SampleBloom(int2 pixel, float threshold, float radius, float softKnee)
+{
+    int r0 = max(1, (int)round(radius * 0.50));
+    int r1 = max(1, (int)round(radius * 0.72));
+    int r2 = max(1, (int)round(radius));
+
+    float3 sum = ExtractBloom(LoadHdrClamped(pixel), threshold, softKnee) * 0.20;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2( r0, 0)), threshold, softKnee) * 0.10;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(-r0, 0)), threshold, softKnee) * 0.10;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(0,  r0)), threshold, softKnee) * 0.10;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(0, -r0)), threshold, softKnee) * 0.10;
+
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2( r1,  r1)), threshold, softKnee) * 0.06;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(-r1,  r1)), threshold, softKnee) * 0.06;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2( r1, -r1)), threshold, softKnee) * 0.06;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(-r1, -r1)), threshold, softKnee) * 0.06;
+
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2( r2, 0)), threshold, softKnee) * 0.05;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(-r2, 0)), threshold, softKnee) * 0.05;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(0,  r2)), threshold, softKnee) * 0.05;
+    sum += ExtractBloom(LoadHdrClamped(pixel + int2(0, -r2)), threshold, softKnee) * 0.05;
+    return sum / 1.04;
+}
+
+[numthreads(8, 8, 1)]
+void BloomCS(uint3 dispatchThreadId : SV_DispatchThreadID)
+{
+    uint2 pixel = dispatchThreadId.xy;
+    if (pixel.x >= (uint)gScreenSize.x || pixel.y >= (uint)gScreenSize.y)
+        return;
+
+    float4 hdrSample = gHdrScene.Load(int3(pixel, 0));
+    float3 hdrColor = max(hdrSample.rgb, 0.0);
+
+    // Keep diagnostic buffers exact and free from presentation processing.
+    if (gDebugMode != 0u)
+    {
+        gFinalOut[pixel] = float4(saturate(hdrColor), hdrSample.a);
+        return;
+    }
+
+    uint mode = min(gBloomMode, 6u);
+    float threshold = max(gBloomThreshold, 0.0);
+    float strength = max(gBloomStrength, 0.0);
+    float radius = clamp(gBloomRadius, 0.5, 32.0);
+    float softKnee = clamp(gBloomSoftKnee, 0.0, 1.0);
+
+    if (mode == 1u)
+    {
+        threshold *= 1.25;
+        strength *= 0.55;
+        radius *= 0.75;
+    }
+    else if (mode == 2u)
+    {
+        threshold *= 0.95;
+        strength *= 0.85;
+    }
+    else if (mode == 3u)
+    {
+        threshold *= 1.65;
+        strength *= 1.20;
+        radius *= 0.85;
+    }
+    else if (mode == 4u)
+    {
+        threshold *= 0.80;
+        strength *= 0.85;
+        radius *= 1.80;
+    }
+    else if (mode == 5u)
+    {
+        radius *= 1.25;
+    }
+    else if (mode == 6u)
+    {
+        threshold *= 0.70;
+        strength *= 1.55;
+        radius *= 2.20;
+    }
+
+    float3 bloom = SampleBloom(int2(pixel), threshold, radius, softKnee);
+    float3 combinedHdr = hdrColor + bloom * strength;
+    gFinalOut[pixel] = float4(ApplyHDRLikeToneMapping(combinedHdr), hdrSample.a);
+}
