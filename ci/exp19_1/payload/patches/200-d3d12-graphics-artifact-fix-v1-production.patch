+static bool QD3D12_GetTextureMipView(const TextureResource& tex, UINT level, TextureMipView& out)
+{
+	if (level == 0)
+	{
+		out.width = tex.width;
+		out.height = tex.height;
+		out.format = tex.format;
+		out.compressed = tex.compressed;
+		out.compressedInternalFormat = tex.compressedInternalFormat;
+		out.compressedBlockBytes = tex.compressedBlockBytes;
+		out.sysmem = &tex.sysmem;
+		return tex.width > 0 && tex.height > 0;
+	}
+
+	const size_t index = (size_t)level - 1u;
+	if (index >= tex.extraMipLevels.size())
+		return false;
+
+	const TextureMipLevel& mip = tex.extraMipLevels[index];
+	if (!mip.defined)
+		return false;
+
+	out.width = mip.width;
+	out.height = mip.height;
+	out.format = mip.format;
+	out.compressed = mip.compressed;
+	out.compressedInternalFormat = mip.compressedInternalFormat;
+	out.compressedBlockBytes = mip.compressedBlockBytes;
+	out.sysmem = &mip.sysmem;
+	return true;
+}
