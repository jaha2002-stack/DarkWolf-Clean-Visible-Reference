+static void QD3D12_ExpandMipRowToRGBA8(const TextureMipView& mip, int y, uint8_t* dst)
+{
+	if (!dst || mip.width <= 0)
+		return;
+
+	const std::vector<uint8_t>& bytes = *mip.sysmem;
+	if (bytes.empty())
+	{
+		memset(dst, 255, (size_t)mip.width * 4u);
+		return;
+	}
+
+	const int srcBpp = BytesPerPixel(mip.format, GL_UNSIGNED_BYTE);
+	const size_t rowOffset = (size_t)y * (size_t)mip.width * (size_t)srcBpp;
+	if (rowOffset >= bytes.size())
+	{
+		memset(dst, 255, (size_t)mip.width * 4u);
+		return;
+	}
+
+	const uint8_t* src = bytes.data() + rowOffset;
+	for (int x = 0; x < mip.width; ++x)
+	{
+		switch (mip.format)
+		{
+		case GL_RGB:
+			dst[x * 4 + 0] = src[x * 3 + 0];
+			dst[x * 4 + 1] = src[x * 3 + 1];
+			dst[x * 4 + 2] = src[x * 3 + 2];
+			dst[x * 4 + 3] = 255;
+			break;
+		case GL_ALPHA:
+			dst[x * 4 + 0] = 255;
+			dst[x * 4 + 1] = 255;
+			dst[x * 4 + 2] = 255;
+			dst[x * 4 + 3] = src[x];
+			break;
+		case GL_LUMINANCE:
+			dst[x * 4 + 0] = src[x];
+			dst[x * 4 + 1] = src[x];
+			dst[x * 4 + 2] = src[x];
+			dst[x * 4 + 3] = 255;
+			break;
+		case GL_INTENSITY:
+			dst[x * 4 + 0] = src[x];
+			dst[x * 4 + 1] = src[x];
+			dst[x * 4 + 2] = src[x];
+			dst[x * 4 + 3] = src[x];
+			break;
+		case GL_RGBA:
+		default:
+			dst[x * 4 + 0] = src[x * 4 + 0];
+			dst[x * 4 + 1] = src[x * 4 + 1];
+			dst[x * 4 + 2] = src[x * 4 + 2];
+			dst[x * 4 + 3] = src[x * 4 + 3];
+			break;
+		}
+	}
+}
