+static int QD3D12_MipDimension(int baseDimension, UINT level)
+{
+	if (baseDimension <= 0)
+		return 0;
+	if (level >= 31)
+		return 1;
+	return (std::max)(1, baseDimension >> level);
+}
+
+static UINT QD3D12_TextureMipCount(const TextureResource& tex)
+{
+	if (tex.width <= 0 || tex.height <= 0)
+		return 1;
+
+	UINT count = 1;
+	for (size_t index = 0; index < tex.extraMipLevels.size(); ++index)
+	{
+		const TextureMipLevel& mip = tex.extraMipLevels[index];
+		const UINT level = (UINT)index + 1u;
+		if (!mip.defined)
+			break;
+
+		const int expectedWidth = QD3D12_MipDimension(tex.width, level);
+		const int expectedHeight = QD3D12_MipDimension(tex.height, level);
+		if (mip.width != expectedWidth || mip.height != expectedHeight)
+		{
+			QD3D12_Log("Texture %u mip %u has size %dx%d; expected %dx%d",
+				tex.glId, level, mip.width, mip.height, expectedWidth, expectedHeight);
+			break;
+		}
+
+		++count;
+		if (expectedWidth == 1 && expectedHeight == 1)
+			break;
+	}
+	return count;
+}
