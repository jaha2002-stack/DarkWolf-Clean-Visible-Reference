+static void UploadTextureMipChain(TextureResource& tex)
+{
+	if (!tex.texture)
+		return;
+
+	const UINT mipCount = QD3D12_TextureMipCount(tex);
+	if (mipCount <= 1)
+	{
+		UploadTextureLegacy(tex);
+		return;
+	}
+
+	const D3D12_RESOURCE_DESC resourceDesc = tex.texture->GetDesc();
+	if ((UINT)resourceDesc.MipLevels != mipCount)
+	{
+		QD3D12_Fatal("D3D12 texture resource mip mismatch: texture=%u resource=%u expected=%u", tex.glId, (UINT)resourceDesc.MipLevels, mipCount);
+		return;
+	}
+
+	std::vector<D3D12_PLACED_SUBRESOURCE_FOOTPRINT> layouts(mipCount);
+	std::vector<UINT> numRows(mipCount);
+	std::vector<UINT64> rowSizes(mipCount);
+	UINT64 totalBytes = 0;
+	g_gl.device->GetCopyableFootprints(
+		&resourceDesc,
+		0,
+		mipCount,
+		0,
+		layouts.data(),
+		numRows.data(),
+		rowSizes.data(),
+		&totalBytes);
+
+	if (totalBytes == 0 || totalBytes > UINT_MAX)
+	{
+		QD3D12_Fatal("D3D12 texture mip upload size invalid: texture=%u bytes=%llu", tex.glId, (unsigned long long)totalBytes);
+		return;
+	}
+
+	UploadAlloc alloc = QD3D12_AllocUpload((UINT)totalBytes, D3D12_TEXTURE_DATA_PLACEMENT_ALIGNMENT);
+	uint8_t* uploadCpu = static_cast<uint8_t*>(alloc.cpu);
+	memset(uploadCpu, 0, (size_t)totalBytes);
+
+	if (tex.state != D3D12_RESOURCE_STATE_COPY_DEST)
+	{
+		D3D12_RESOURCE_BARRIER toCopy{};
+		toCopy.Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION;
+		toCopy.Transition.pResource = tex.texture.Get();
+		toCopy.Transition.StateBefore = tex.state;
+		toCopy.Transition.StateAfter = D3D12_RESOURCE_STATE_COPY_DEST;
+		toCopy.Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
+		g_gl.cmdList->ResourceBarrier(1, &toCopy);
+		tex.state = D3D12_RESOURCE_STATE_COPY_DEST;
+	}
+
+	for (UINT level = 0; level < mipCount; ++level)
+	{
+		TextureMipView mip{};
+		if (!QD3D12_GetTextureMipView(tex, level, mip))
+		{
+			QD3D12_Fatal("D3D12 texture missing mip data: texture=%u level=%u", tex.glId, level);
+			return;
+		}
+
+		uint8_t* dstBase = uploadCpu + (size_t)layouts[level].Offset;
+		const UINT dstRowPitch = layouts[level].Footprint.RowPitch;
+
+		if (mip.compressed)
+		{
+			const UINT blockBytes = mip.compressedBlockBytes ? mip.compressedBlockBytes : QD3D12_CompressedTextureBlockBytes(mip.compressedInternalFormat);
+			const UINT blocksWide = QD3D12_CompressedTextureBlocksWide(mip.width);
+			const UINT blocksHigh = QD3D12_CompressedTextureBlocksHigh(mip.height);
+			const size_t srcRowBytes = (size_t)blocksWide * (size_t)blockBytes;
+			const std::vector<uint8_t>& bytes = *mip.sysmem;
+			for (UINT row = 0; row < blocksHigh; ++row)
+			{
+				const size_t srcOffset = (size_t)row * srcRowBytes;
+				if (srcOffset >= bytes.size())
+					break;
+				const size_t copyBytes = (std::min)(srcRowBytes, bytes.size() - srcOffset);
+				memcpy(dstBase + (size_t)row * dstRowPitch, bytes.data() + srcOffset, copyBytes);
+			}
+		}
+		else
+		{
+			for (int row = 0; row < mip.height; ++row)
+				QD3D12_ExpandMipRowToRGBA8(mip, row, dstBase + (size_t)row * dstRowPitch);
+		}
+
+		D3D12_TEXTURE_COPY_LOCATION srcLoc{};
+		srcLoc.pResource = g_currentWindow->upload.resource[g_currentWindow->frameIndex].Get();
+		srcLoc.Type = D3D12_TEXTURE_COPY_TYPE_PLACED_FOOTPRINT;
+		srcLoc.PlacedFootprint = layouts[level];
+		srcLoc.PlacedFootprint.Offset += alloc.offset;
+
+		D3D12_TEXTURE_COPY_LOCATION dstLoc{};
+		dstLoc.pResource = tex.texture.Get();
+		dstLoc.Type = D3D12_TEXTURE_COPY_TYPE_SUBRESOURCE_INDEX;
+		dstLoc.SubresourceIndex = level;
+
+		g_gl.cmdList->CopyTextureRegion(&dstLoc, 0, 0, 0, &srcLoc, nullptr);
+	}
+
+	D3D12_RESOURCE_BARRIER toSrv{};
+	toSrv.Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION;
+	toSrv.Transition.pResource = tex.texture.Get();
+	toSrv.Transition.StateBefore = D3D12_RESOURCE_STATE_COPY_DEST;
+	toSrv.Transition.StateAfter = D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE;
+	toSrv.Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
+	g_gl.cmdList->ResourceBarrier(1, &toSrv);
+
+	tex.state = D3D12_RESOURCE_STATE_PIXEL_SHADER_RESOURCE;
+	tex.gpuValid = true;
+}
+
+static void UploadTexture(TextureResource& tex)
+{
+	if (QD3D12_TextureMipCount(tex) > 1)
+		UploadTextureMipChain(tex);
+	else
+		UploadTextureLegacy(tex);
+}
