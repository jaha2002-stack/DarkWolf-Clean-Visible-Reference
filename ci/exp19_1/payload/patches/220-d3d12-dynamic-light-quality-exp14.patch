+float DynamicLightPointFalloff(float dist, float radius)
+{
+    float x = saturate(1.0 - dist / max(radius, 1e-4));
+    if (gDynamicLightQualityMode == 1u || gDynamicLightQualityMode == 5u)
+    {
+        // Broader C1-continuous falloff: clearly fills the authored light radius
+        // without the abrupt shoulder of the original squared ramp.
+        return x * x * (3.0 - 2.0 * x);
+    }
+    if (gDynamicLightQualityMode == 6u)
+    {
+        // Tighter cinematic falloff keeps dark areas dark while preserving a
+        // strong local pool around torches and lamps.
+        return x * x * x;
+    }
+    return x * x;
+}
+
+float DynamicLightRectFalloff(float dist, float radius)
+{
+    float x = saturate(1.0 - dist / max(radius, 1e-4));
+    if (gDynamicLightQualityMode == 1u || gDynamicLightQualityMode == 5u)
+        return x * x * (3.0 - 2.0 * x);
+    if (gDynamicLightQualityMode == 6u)
+        return x * x * x;
+    return x * x * x * x;
+}
+
+float3 DynamicLightColor(float3 sourceColor, bool fillOnly)
+{
+    if (fillOnly)
+    {
+        if (gDynamicLightQualityMode >= 4u)
+            return lerp(sourceColor, float3(1.00, 0.96, 0.90), 0.35);
+        return sourceColor;
+    }
+
+    float warmEvidence = saturate((sourceColor.r - sourceColor.b) * 2.2 +
+                                  (sourceColor.g - sourceColor.b) * 0.8);
+    float warmStrength = 0.0;
+    if (gDynamicLightQualityMode == 2u)
+        warmStrength = 0.80;
+    else if (gDynamicLightQualityMode == 5u)
+        warmStrength = 0.55;
+    else if (gDynamicLightQualityMode == 6u)
+        warmStrength = 0.72;
+
+    float luminance = max(dot(sourceColor, float3(0.2126, 0.7152, 0.0722)), 0.001);
+    float3 warmTarget = luminance * float3(1.20, 0.72, 0.36);
+    return lerp(sourceColor, warmTarget, warmEvidence * warmStrength);
+}
 
+float DynamicLightDiffuseScale(bool fillOnly)
+{
+    if (gDynamicLightQualityMode == 4u)
+        return fillOnly ? 0.38 : 1.25;
+    if (gDynamicLightQualityMode == 5u)
+        return fillOnly ? 0.58 : 1.16;
+    if (gDynamicLightQualityMode == 6u)
+        return fillOnly ? 0.45 : 1.38;
+    return 1.0;
+}
+
+float DynamicLightSpecularScale(bool fillOnly)
+{
+    if (gDynamicLightQualityMode == 4u)
+        return fillOnly ? 0.86 : 1.12;
+    if (gDynamicLightQualityMode == 5u)
+        return fillOnly ? 0.92 : 1.12;
+    if (gDynamicLightQualityMode == 6u)
+        return fillOnly ? 1.00 : 1.28;
+    return 1.0;
+}
+
+float3 DynamicLightSoftPeak(float3 value)
+{
+    float knee = 0.0;
+    if (gDynamicLightQualityMode == 3u)
+        knee = 1.75;
+    else if (gDynamicLightQualityMode == 5u)
+        knee = 2.20;
+    else if (gDynamicLightQualityMode == 6u)
+        knee = 2.55;
+    else
+        return value;
+
+    float peak = max(value.r, max(value.g, value.b));
+    if (peak <= knee)
+        return value;
+
+    float excess = peak - knee;
+    float compressedPeak = knee + excess / (1.0 + excess);
+    return value * (compressedPeak / max(peak, 1e-5));
+}
