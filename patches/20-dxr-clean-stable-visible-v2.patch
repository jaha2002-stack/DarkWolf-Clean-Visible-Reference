+	auto hashU32 = [&](unsigned int value)
+	{
+		h ^= (unsigned long long)value;
+		h *= fnvPrime;
+	};
+
+	hashU32((unsigned int)(endVertex - startVertex));
+	hashU32((unsigned int)(endIndex - startIndex));
+
+	for (int i = startVertex; i < endVertex; ++i)
