+float ComputeContactAO(float3 worldPos, float3 N, uint2 pixel)
+{
+    if (gContactAOEnabled == 0 || gContactAOStrength <= 0.0)
+        return 1.0;
+
+    const uint sampleCount = 4u;
+    float3 tangent, bitangent;
+    BuildOrthonormalBasis(N, tangent, bitangent);
+    float rand = Hash12((float2)pixel * 1.91 + worldPos.xy + worldPos.zz);
+    float visibility = 0.0;
+
+    [unroll]
+    for (uint i = 0; i < sampleCount; ++i)
+    {
+        float2 xi = Hammersley2D(i, sampleCount, rand);
+        float3 h = CosineSampleHemisphere(xi);
+        // Bias toward grazing/local directions so this behaves as grounding,
+        // not as another long-range cast-shadow system.
+        h.z = lerp(0.20, 0.75, h.z);
+        float3 dir = normalize(tangent * h.x + bitangent * h.y + N * h.z);
+        float3 origin = worldPos + N * max(gShadowBias * 1.25, 0.025);
+        visibility += TraceShadow(origin, dir, max(gContactAORadius, 1.0));
+    }
+
+    visibility /= (float)sampleCount;
+    return lerp(1.0, visibility, saturate(gContactAOStrength));
+}
+
+float3 SkyColorForDirection(float3 dir)
+{
+    float up = saturate(dir.z * 0.5 + 0.5);
+    float horizon = 1.0 - abs(dir.z);
+    float3 low = float3(0.22, 0.24, 0.28);
+    float3 high = float3(0.48, 0.53, 0.62);
+    float3 sky = lerp(low, high, up);
+    sky += float3(0.08, 0.06, 0.04) * horizon;
+    return sky;
+}
+
+float3 ComputeGI(float3 worldPos, float3 N, float3 baseAlbedo, uint2 pixel)
+{
+    if (gGIEnabled == 0 || gGIStrength <= 0.0)
+        return 0.0;
+
+    uint sampleCount = clamp(gGISamples, 1u, 4u);
+    float3 tangent, bitangent;
+    BuildOrthonormalBasis(N, tangent, bitangent);
+    float rand = Hash12((float2)pixel * 0.61 + worldPos.xy + worldPos.zz);
+    float3 accum = 0.0;
+
+    [loop]
+    for (uint i = 0; i < sampleCount; ++i)
+    {
+        float2 xi = Hammersley2D(i, sampleCount, rand);
+        float3 h = CosineSampleHemisphere(xi);
+        float3 dir = normalize(tangent * h.x + bitangent * h.y + N * h.z);
+        float3 origin = worldPos + N * max(gShadowBias * 1.5, 0.03);
+        float visibility = TraceShadow(origin, dir, max(gGIMaxDistance, 8.0));
+        float3 openColor = SkyColorForDirection(dir) * 0.55 + gAmbientColor.rgb * 0.45;
+        float3 blockedBounce = gAmbientColor.rgb * 0.18;
+        accum += lerp(blockedBounce, openColor, visibility);
+    }
+
+    float3 gi = baseAlbedo * (accum / (float)sampleCount) * max(gGIStrength, 0.0);
+    float indirectLimit = max(gIndirectClamp, 0.0);
+    return min(gi, float3(indirectLimit, indirectLimit, indirectLimit));
+}
