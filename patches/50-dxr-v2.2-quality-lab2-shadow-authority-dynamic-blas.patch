 cvar_t  *r_dxrFallbackCastsShadows;
 cvar_t  *r_dxrFallbackDiffuseScale;
 cvar_t  *r_dxrHighlightCompression;
+cvar_t  *r_dxrShadowRetention;
+cvar_t  *r_dxrShadowCompositeMinLight;
+cvar_t  *r_dxrDynamicBLASFullRebuild;
 cvar_t  *r_dxrDebugLights;
 cvar_t  *r_dxrSafeMode;
 cvar_t  *r_dxrErrorLimit;
@@ -1027,6 +1030,9 @@ void R_Register( void ) {
 	r_dxrFallbackCastsShadows = ri.Cvar_Get( "r_dxrFallbackCastsShadows", "0", CVAR_ARCHIVE );
 	r_dxrFallbackDiffuseScale = ri.Cvar_Get( "r_dxrFallbackDiffuseScale", "0.35", CVAR_ARCHIVE );
 	r_dxrHighlightCompression = ri.Cvar_Get( "r_dxrHighlightCompression", "1.0", CVAR_ARCHIVE );
+	r_dxrShadowRetention = ri.Cvar_Get( "r_dxrShadowRetention", "0.60", CVAR_ARCHIVE );
+	r_dxrShadowCompositeMinLight = ri.Cvar_Get( "r_dxrShadowCompositeMinLight", "0.025", CVAR_ARCHIVE );
+	r_dxrDynamicBLASFullRebuild = ri.Cvar_Get( "r_dxrDynamicBLASFullRebuild", "1", CVAR_ARCHIVE );
 	r_dxrDebugLights = ri.Cvar_Get( "r_dxrDebugLights", "0", CVAR_ARCHIVE );
 	r_dxrSafeMode = ri.Cvar_Get( "r_dxrSafeMode", "1", CVAR_ARCHIVE );
 	r_dxrErrorLimit = ri.Cvar_Get( "r_dxrErrorLimit", "4", CVAR_ARCHIVE );
diff --git a/src/renderer/tr_local.h b/src/renderer/tr_local.h
index 6bfa988..7c92580 100644
--- a/src/renderer/tr_local.h
+++ b/src/renderer/tr_local.h
@@ -1137,13 +1137,16 @@ extern cvar_t   *r_dxrAmbientIntensity; // global ambient lift for the DXR resol
 extern cvar_t   *r_dxrLegacyBlend;      // how much of the original RTCW shading is preserved
 extern cvar_t   *r_dxrExposure;         // post exposure applied to the DXR resolve
 extern cvar_t   *r_dxrDebug;            // periodic DXR state logging to the console
-extern cvar_t   *r_dxrDebugMode;        // 0 normal, 1 RT, 2 AO/sky, 3 albedo, 4 lighting, 5/8 multi-light visibility, 6 unshadowed direct, 7 shadowed direct, 9 fill, 10 direct share
+extern cvar_t   *r_dxrDebugMode;        // 0 normal, 1 RT, 2 AO/sky, 3 albedo, 4 lighting, 5/8 physical visibility, 6/7 direct, 9 fill, 10 share, 11 evidence, 12 retained visibility, 13 support shadow
 extern cvar_t   *r_dxrFallbackLight;    // optional camera-side test light for verification
 extern cvar_t   *r_dxrFallbackLightRadius;
 extern cvar_t   *r_dxrFallbackLightIntensity;
