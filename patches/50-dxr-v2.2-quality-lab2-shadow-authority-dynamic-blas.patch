+				"DXR v2.2 Quality Lab 2: meshes=%u instances=%u lights=%u selected=%u dropped=%u point=%u rect=%u fill=%u maxRadius=%.1f maxIntensity=%.2f async=%d cpuSync=%d samples=%d/%d ao=%d sky=%d fallback=%d fallbackShadows=%d fillScale=%.2f highlight=%.2f retention=%.2f minLight=%.3f dynFull=%d dynUpdates=%llu dynRebuilds=%llu dynRefits=%llu bias=%.4f ambient=%.2f legacy=%.2f exposure=%.2f debugMode=%d\n",
 				glRaytracingGetMeshCount(),
 				glRaytracingGetInstanceCount(),
 				glRaytracingLightingGetLightCount(),
@@ -1329,6 +1333,12 @@ static void RB_RunRaytracedLightingPass(void)
 				r_dxrFallbackCastsShadows ? r_dxrFallbackCastsShadows->integer : 0,
 				r_dxrFallbackDiffuseScale ? r_dxrFallbackDiffuseScale->value : 0.35f,
 				r_dxrHighlightCompression ? r_dxrHighlightCompression->value : 1.0f,
+				r_dxrShadowRetention ? r_dxrShadowRetention->value : 0.60f,
+				r_dxrShadowCompositeMinLight ? r_dxrShadowCompositeMinLight->value : 0.025f,
+				r_dxrDynamicBLASFullRebuild ? r_dxrDynamicBLASFullRebuild->integer : 1,
+				(unsigned long long)glRaytracingGetDynamicMeshUpdateCount(),
