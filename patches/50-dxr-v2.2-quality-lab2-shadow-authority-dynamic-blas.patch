 				r_dxrShadowBias ? r_dxrShadowBias->value : 0.0f,
 				r_dxrAmbientIntensity ? r_dxrAmbientIntensity->value : 0.0f,
 				r_dxrLegacyBlend ? r_dxrLegacyBlend->value : 0.0f,
@@ -1344,7 +1354,7 @@ static void RB_RunRaytracedLightingPass(void)
 				if (!glRaytracingLightingGetSelectedLight((uint32_t)i, &light))
 					break;
 				ri.Printf(PRINT_ALL,
-					"  QL1 light[%d] type=%s fill=%d persistent=%d pos=(%.1f %.1f %.1f) radius=%.1f intensity=%.2f color=(%.2f %.2f %.2f)\n",
+					"  QL2 light[%d] type=%s fill=%d persistent=%d pos=(%.1f %.1f %.1f) radius=%.1f intensity=%.2f color=(%.2f %.2f %.2f)\n",
 					i,
 					(light.type == GL_RAYTRACING_LIGHT_TYPE_RECT) ? "rect" : "point",
 					(light.pad1 >= 0.5f) ? 1 : 0,
diff --git a/src/renderer/tr_cmesh.cpp b/src/renderer/tr_cmesh.cpp
index 82b1771..28d6a44 100644
--- a/src/renderer/tr_cmesh.cpp
+++ b/src/renderer/tr_cmesh.cpp
@@ -316,6 +316,15 @@ void R_AddMDCSurfaces( trRefEntity_t *ent ) {
 		ent->e.oldframe %= tr.currentModel->mdc[0]->numFrames;
 	}
 
+	// Some looping map models (notably torture/cage1 and cage2) submit the
+	// transition numFrames-1 -> numFrames without RF_WRAP_FRAMES.  Preserve the
+	// last-to-first interpolation instead of resetting both frames to zero.
+	const int dxrNumFrames = tr.currentModel->mdc[0]->numFrames;
+	if ( dxrNumFrames > 0 && ent->e.oldframe == dxrNumFrames - 1 &&
+		ent->e.frame == dxrNumFrames ) {
+		ent->e.frame = 0;
+	}
+
 	//
 	// Validate the frames so there is no chance of a crash.
 	// This will write directly into the entity structure, so
diff --git a/src/renderer/tr_init.cpp b/src/renderer/tr_init.cpp
index 2bfd3d3..90039d1 100644
--- a/src/renderer/tr_init.cpp
+++ b/src/renderer/tr_init.cpp
