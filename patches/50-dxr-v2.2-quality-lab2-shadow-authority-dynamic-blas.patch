From 005692ebcaa26b720968445e0f79f9c8d25dba2a Mon Sep 17 00:00:00 2001
From: OpenAI <openai@example.com>
Date: Mon, 20 Jul 2026 04:44:24 +0000
Subject: [PATCH] Add QL2 shadow authority and dynamic BLAS rebuilds

---
 src/opengl/gl_d3d12raylight.cpp | 150 ++++++++++++++++++++++++++++----
 src/opengl/opengl.h             |  10 ++-
 src/renderer/tr_backend.cpp     |  16 +++-
 src/renderer/tr_cmesh.cpp       |   9 ++
 src/renderer/tr_init.cpp        |   6 ++
 src/renderer/tr_local.h         |   5 +-
 src/renderer/tr_mesh.cpp        |   9 ++
 7 files changed, 181 insertions(+), 24 deletions(-)

diff --git a/src/opengl/gl_d3d12raylight.cpp b/src/opengl/gl_d3d12raylight.cpp
index 43213e6..eaf7b9a 100644
--- a/src/opengl/gl_d3d12raylight.cpp
+++ b/src/opengl/gl_d3d12raylight.cpp
@@ -586,6 +586,7 @@ struct glRaytracingMeshRecord_t
 	int blasBuilt;
 	int dirty;
 	int currentBlasIndex;
+	int forceFullRebuild;
 
 	glRaytracingMeshRecord_t()
 	{
@@ -597,6 +598,7 @@ struct glRaytracingMeshRecord_t
 		blasBuilt = 0;
 		dirty = 0;
 		currentBlasIndex = 0;
+		forceFullRebuild = 0;
 	}
 };
 
@@ -665,6 +667,10 @@ struct glRaytracingSceneState_t
 	int tlasNeedsUpdate;
 	int currentTLASIndex;
 
+	uint64_t dynamicMeshUpdates;
+	uint64_t dynamicFullRebuilds;
+	uint64_t dynamicRefits;
+
 	glRaytracingSceneState_t()
 	{
 		nextMeshHandle = 1;
@@ -679,10 +685,14 @@ struct glRaytracingSceneState_t
 		tlasNeedsRebuild = 1;
 		tlasNeedsUpdate = 1;
 		currentTLASIndex = 0;
+		dynamicMeshUpdates = 0;
+		dynamicFullRebuilds = 0;
+		dynamicRefits = 0;
 	}
 };
 
 static glRaytracingSceneState_t g_glRaytracingScene;
+static int g_glRaytracingDynamicFullRebuild = 1;
 
 void glRaytracingClear(void);
 
@@ -1064,6 +1074,7 @@ static int glRaytracingBuildDirtyMeshesInternal(void)
 		D3D12_BUILD_RAYTRACING_ACCELERATION_STRUCTURE_DESC buildDesc;
 		ID3D12Resource* barrierResource;
 		int newBlasIndex;
+		int performedUpdate;
 	};
 
 	std::vector<glRaytracingMeshBuildInfo_t> builds;
@@ -1099,14 +1110,23 @@ static int glRaytracingBuildDirtyMeshesInternal(void)
 		info.inputs.DescsLayout = D3D12_ELEMENTS_LAYOUT_ARRAY;
 		info.inputs.NumDescs = 1;
 		info.inputs.pGeometryDescs = &info.geomDesc;
+		const bool isDynamicRebuild =
+			(mesh->blasBuilt != 0) && (mesh->descCpu.allowUpdate != 0) &&
+			(mesh->forceFullRebuild != 0);
+		const bool canUpdateInPlace =
+			(mesh->blasBuilt != 0) && (mesh->descCpu.allowUpdate != 0) &&
+			!isDynamicRebuild;
+
 		info.inputs.Flags = mesh->descCpu.allowUpdate
-			? (D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_PREFER_FAST_TRACE |
+			? ((isDynamicRebuild
+				? D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_PREFER_FAST_BUILD
+				: D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_PREFER_FAST_TRACE) |
 				D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_ALLOW_UPDATE)
 			: D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_PREFER_FAST_TRACE;
 
-		const bool canUpdateInPlace = (mesh->blasBuilt != 0) && (mesh->descCpu.allowUpdate != 0);
 		if (canUpdateInPlace)
 			info.inputs.Flags |= D3D12_RAYTRACING_ACCELERATION_STRUCTURE_BUILD_FLAG_PERFORM_UPDATE;
+		info.performedUpdate = canUpdateInPlace ? 1 : 0;
 
 		D3D12_RAYTRACING_ACCELERATION_STRUCTURE_PREBUILD_INFO prebuild = {};
 		g_glRaytracingCmd.device->GetRaytracingAccelerationStructurePrebuildInfo(&info.inputs, &prebuild);
@@ -1116,7 +1136,10 @@ static int glRaytracingBuildDirtyMeshesInternal(void)
 			return 0;
 		}
 
-		if (!glRaytracingEnsureMeshScratch(mesh, prebuild.ScratchDataSizeInBytes))
+		const UINT64 scratchBytes = (canUpdateInPlace && prebuild.UpdateScratchDataSizeInBytes > 0)
+			? prebuild.UpdateScratchDataSizeInBytes
+			: prebuild.ScratchDataSizeInBytes;
+		if (!glRaytracingEnsureMeshScratch(mesh, scratchBytes))
 			return 0;
 		if (!glRaytracingEnsureMeshResultBuffers(mesh, prebuild.ResultDataMaxSizeInBytes))
 			return 0;
@@ -1163,6 +1186,11 @@ static int glRaytracingBuildDirtyMeshesInternal(void)
 		mesh->currentBlasIndex = builds[i].newBlasIndex;
 		mesh->blasBuilt = 1;
 		mesh->dirty = 0;
+		if (mesh->forceFullRebuild)
+			++g_glRaytracingScene.dynamicFullRebuilds;
+		else if (builds[i].performedUpdate)
+			++g_glRaytracingScene.dynamicRefits;
+		mesh->forceFullRebuild = 0;
 	}
 
 	g_glRaytracingScene.tlasNeedsRebuild = 1;
@@ -1471,6 +1499,9 @@ void glRaytracingClear(void)
 	g_glRaytracingScene.tlasNeedsRebuild = 1;
 	g_glRaytracingScene.tlasNeedsUpdate = 1;
 	g_glRaytracingScene.currentTLASIndex = 0;
+	g_glRaytracingScene.dynamicMeshUpdates = 0;
+	g_glRaytracingScene.dynamicFullRebuilds = 0;
+	g_glRaytracingScene.dynamicRefits = 0;
 }
 
 glRaytracingMeshHandle_t glRaytracingCreateMesh(const glRaytracingMeshDesc_t* desc)
@@ -1549,6 +1580,9 @@ int glRaytracingUpdateMesh(glRaytracingMeshHandle_t meshHandle, const glRaytraci
 	}
 
 	mesh->dirty = 1;
+	mesh->forceFullRebuild = (canReuseGeometryBuffers && mesh->blasBuilt &&
+		g_glRaytracingDynamicFullRebuild) ? 1 : 0;
+	++g_glRaytracingScene.dynamicMeshUpdates;
 
 	for (size_t i = 0; i < g_glRaytracingScene.instances.size(); ++i)
 	{
@@ -1573,6 +1607,26 @@ int glRaytracingUpdateMesh(glRaytracingMeshHandle_t meshHandle, const glRaytraci
 	return glRaytracingShouldAbortWork() ? 0 : 1;
 }
 
+void glRaytracingSetDynamicGeometryOptions(int fullRebuild)
+{
+	g_glRaytracingDynamicFullRebuild = fullRebuild ? 1 : 0;
+}
+
+uint64_t glRaytracingGetDynamicMeshUpdateCount(void)
+{
+	return g_glRaytracingScene.dynamicMeshUpdates;
+}
+
+uint64_t glRaytracingGetDynamicFullRebuildCount(void)
+{
+	return g_glRaytracingScene.dynamicFullRebuilds;
+}
+
+uint64_t glRaytracingGetDynamicRefitCount(void)
+{
+	return g_glRaytracingScene.dynamicRefits;
+}
+
 void glRaytracingDeleteMesh(glRaytracingMeshHandle_t meshHandle)
 {
 	glRaytracingMeshRecord_t* mesh = glRaytracingFindMesh(meshHandle);
@@ -1764,9 +1818,11 @@ struct glRaytracingLightingConstants_t
 	uint32_t frameIndex;
 	float fallbackDiffuseScale;
 	float highlightCompression;
+	float shadowRetention;
+	float shadowCompositeMinLight;
 };
 
-static_assert(sizeof(glRaytracingLightingConstants_t) == 256,
+static_assert(sizeof(glRaytracingLightingConstants_t) == 264,
 	"DXR lighting constant buffer layout must match the embedded HLSL cbuffer");
 
 struct glRaytracingLightingState_t
@@ -1870,6 +1926,8 @@ cbuffer LightingCB : register(b0)
     uint     gFrameIndex;
     float    gFallbackDiffuseScale;
     float    gHighlightCompression;
+    float    gShadowRetention;
+    float    gShadowCompositeMinLight;
 };
 
 StructuredBuffer<Light> gLights : register(t0);
@@ -2399,6 +2457,8 @@ void RayGen()
     float3 fillDiffuseAccum = 0.0;
     float3 authoredSpecularAccum = 0.0;
     float3 fillSpecularAccum = 0.0;
+    float strongestShadowLoss = 0.0;
+    float strongestShadowFraction = 0.0;
 
     [loop]
     for (uint i = 0; i < gLightCount; ++i)
@@ -2452,6 +2512,11 @@ void RayGen()
                 authoredDirectUnshadowed += unshadowedDiffuse;
                 authoredDirectShadowed += unshadowedDiffuse * shadow;
                 authoredSpecularAccum += unshadowedSpecular * shadow;
+
+                float pointLum = Luminance(unshadowedDiffuse);
+                float pointOcclusion = saturate(1.0 - shadow);
+                strongestShadowLoss = max(strongestShadowLoss, pointLum * pointOcclusion);
+                strongestShadowFraction = max(strongestShadowFraction, pointOcclusion);
             }
         }
         else if (Lgt.type == GL_RAYTRACING_LIGHT_TYPE_RECT)
@@ -2522,11 +2587,45 @@ void RayGen()
             authoredDirectUnshadowed += rectDirect;
             authoredDirectShadowed += rectDirect * shadow;
             authoredSpecularAccum += rectSpecAccum * atten * shadow;
+
+            float rectLum = Luminance(rectDirect);
+            float rectOcclusion = saturate(1.0 - shadow);
+            strongestShadowLoss = max(strongestShadowLoss, rectLum * rectOcclusion);
+            strongestShadowFraction = max(strongestShadowFraction, rectOcclusion);
         }
     }
 
-    float3 diffuseLighting = indirectLighting + fillDiffuseAccum + authoredDirectShadowed;
-    float3 specularAccum = authoredSpecularAccum + fillSpecularAccum;
+    // Energy-weighted visibility remains the physically correct multi-light
+    // result.  Quality Lab 2 adds a separate local occluder-confidence term so
+    // a valid grille/character/cage silhouette is not erased merely because
+    // the old lightmap, ambient lift or camera fill is brighter than the local
+    // authored light.  The confidence is driven by actual lost direct energy,
+    // so it cannot recreate the old light-radius circles in empty space.
+    float authoredUnshadowedLum = Luminance(authoredDirectUnshadowed);
+    float authoredShadowedLum = Luminance(authoredDirectShadowed);
+    float multiLightVisibility = (authoredUnshadowedLum > 1e-5)
+        ? saturate(authoredShadowedLum / authoredUnshadowedLum)
+        : 1.0;
+
+    float physicalOcclusion = saturate(1.0 - multiLightVisibility);
+    float minShadowLight = max(gShadowCompositeMinLight, 0.0001);
+    float shadowEvidenceConfidence = smoothstep(
+        minShadowLight, minShadowLight * 5.0, strongestShadowLoss);
+    float retainedOcclusion = strongestShadowFraction *
+        shadowEvidenceConfidence * saturate(gShadowRetention);
+    float compositeOcclusion = saturate(max(physicalOcclusion, retainedOcclusion));
+    float compositeVisibility = max(1.0 - compositeOcclusion, saturate(gShadowMinVisibility));
+
+    // Preserve indirect/fill illumination, but do not let it completely wash
+    // out a ray-confirmed local silhouette.  This is deliberately partial: the
+    // room remains readable and multi-light fill still works.
+    float supportShadowWeight = 0.20 + 0.30 * saturate(gShadowRetention);
+    float supportShadow = lerp(1.0, compositeVisibility, supportShadowWeight);
+    float3 diffuseLighting =
+        authoredDirectShadowed + (indirectLighting + fillDiffuseAccum) * supportShadow;
+
+    float fillSpecularShadow = lerp(1.0, compositeVisibility, 0.20 * saturate(gShadowRetention));
+    float3 specularAccum = authoredSpecularAccum + fillSpecularAccum * fillSpecularShadow;
 
     diffuseLighting *= ao;
     specularAccum *= lerp(1.0, ao, 0.5);
@@ -2537,24 +2636,14 @@ void RayGen()
         specularAccum *= 1.05;
     }
 
-    // Energy-weighted visibility of all authored direct lights.  An unoccluded
-    // second light correctly fills a shadow from the first; a camera fill never
-    // enters this ratio and therefore cannot rotate or erase world shadows.
-    float authoredUnshadowedLum = Luminance(authoredDirectUnshadowed);
-    float authoredShadowedLum = Luminance(authoredDirectShadowed);
-    float multiLightVisibility = (authoredUnshadowedLum > 1e-5)
-        ? saturate(authoredShadowedLum / authoredUnshadowedLum)
-        : 1.0;
-
     float supportLum = Luminance(indirectLighting + fillDiffuseAccum);
     float authoredDirectShare = (authoredUnshadowedLum > 1e-5)
         ? saturate(authoredUnshadowedLum / (authoredUnshadowedLum + supportLum + 0.15))
         : 0.0;
 
-    float legacyShadowTarget = max(multiLightVisibility, saturate(gShadowMinVisibility));
     float legacyShadowWeight = saturate(gLegacyShadowStrength) *
-        smoothstep(0.05, 0.65, authoredDirectShare);
-    float legacyShadow = lerp(1.0, legacyShadowTarget, legacyShadowWeight);
+        shadowEvidenceConfidence;
+    float legacyShadow = lerp(1.0, compositeVisibility, legacyShadowWeight);
 
     if (geoFlag == GEOMETRY_FLAG_UNLIT)
     {
@@ -2607,6 +2696,19 @@ void RayGen()
         {
             finalColor = float3(authoredDirectShare, authoredDirectShare, authoredDirectShare);
         }
+        else if (gDebugMode == 11)
+        {
+            float evidenceView = saturate(strongestShadowLoss / max(gShadowCompositeMinLight * 5.0, 0.0001));
+            finalColor = float3(evidenceView, evidenceView, evidenceView);
+        }
+        else if (gDebugMode == 12)
+        {
+            finalColor = float3(compositeVisibility, compositeVisibility, compositeVisibility);
+        }
+        else if (gDebugMode == 13)
+        {
+            finalColor = float3(supportShadow, supportShadow, supportShadow);
+        }
 
         gOutputTex[pixel] = float4(finalColor, albedoSample.a);
     }
@@ -3149,6 +3251,8 @@ bool glRaytracingLightingInit(void)
 	g_glRaytracingLighting.constants.frameIndex = 0u;
 	g_glRaytracingLighting.constants.fallbackDiffuseScale = 0.35f;
 	g_glRaytracingLighting.constants.highlightCompression = 1.0f;
+	g_glRaytracingLighting.constants.shadowRetention = 0.60f;
+	g_glRaytracingLighting.constants.shadowCompositeMinLight = 0.025f;
 
 	glRaytracingLightingUpdateConstants();
 
@@ -3300,12 +3404,20 @@ void glRaytracingLightingSetDebugMode(uint32_t mode)
 	glRaytracingLightingUpdateConstants();
 }
 
-void glRaytracingLightingSetCompositeOptions(float fallbackDiffuseScale, float highlightCompression)
+void glRaytracingLightingSetCompositeOptions(
+	float fallbackDiffuseScale,
+	float highlightCompression,
+	float shadowRetention,
+	float shadowCompositeMinLight)
 {
 	g_glRaytracingLighting.constants.fallbackDiffuseScale =
 		glRaytracingClamp(fallbackDiffuseScale, 0.0f, 1.0f);
 	g_glRaytracingLighting.constants.highlightCompression =
 		glRaytracingClamp(highlightCompression, 0.0f, 1.0f);
+	g_glRaytracingLighting.constants.shadowRetention =
+		glRaytracingClamp(shadowRetention, 0.0f, 1.0f);
+	g_glRaytracingLighting.constants.shadowCompositeMinLight =
+		glRaytracingClamp(shadowCompositeMinLight, 0.0001f, 2.0f);
 	glRaytracingLightingUpdateConstants();
 }
 
